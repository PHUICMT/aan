{
  "name": "aan",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:build": "cd src-tauri && cargo build",
    "e2e:report": "playwright show-report tests/e2e/.report",
    "test:fixtures": "tsx tests/fixtures/generate.ts",
    "test:fixtures:clean": "node -e \"require('fs').rmSync('tests/fixtures/build',{recursive:true,force:true})\""
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/cli": "^2.11.1",
    "@tauri-apps/plugin-notification": "^2.0.0",
    "@testing-library/svelte": "^5.2.0",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^24.12.3",
    "@vitest/coverage-v8": "^4.1.6",
    "better-sqlite3": "^12.10.0",
    "jsdom": "^25.0.0",
    "pdf-lib": "^1.17.1",
    "playwright-core": "^1.60.0",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "tsx": "^4.22.3",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "pdfjs-dist": "^5.7.284"
  }
}
